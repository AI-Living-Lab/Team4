# ============================================================
# Team4 환경 변수 템플릿 — 복사 후 사용
#   cp paths.env.example paths.env
#   # paths.env 를 환경에 맞게 수정 (특히 HF_TOKEN)
# ============================================================

# 프로젝트 루트
export BASE_DIR=/workspace/tti_natural/Team4

# 외부 데이터 (UnAV-100 비디오/오디오 원본 등)
export DATA_DIR=/workspace/datasets

# 체크포인트 루트 (sft / gdpo / base 하위 폴더로 분리 저장)
export CKPT_DIR=/workspace/checkpoints
export CHECKPOINTS_DIR=${CKPT_DIR}  # legacy alias (scripts/ 안 일부에서 참조)

# JSON / 출력 디렉토리
export JSON_DIR=${BASE_DIR}/data
export TRAIN_DIR=${JSON_DIR}/train      # SFT/GDPO 학습용 JSON
export TEST_DIR=${JSON_DIR}/test        # 평가용 chunk JSON
export EVAL_DIR=${BASE_DIR}/outputs

# HuggingFace
export HF_HOME=/workspace/models/.cache/huggingface
# HF Hub 업로드용 (선택). https://huggingface.co/settings/tokens 에서 write 권한 토큰 발급.
export HF_TOKEN=
