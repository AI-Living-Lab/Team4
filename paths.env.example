# ============================================================
# paths.env.example - 경로 설정 템플릿
# 이 파일을 복사해서 paths.env로 만들고 환경에 맞게 수정하세요.
# paths.env는 .gitignore에 포함되어 있어 git에 올라가지 않습니다.
# ============================================================

# --- RunPod 서버 예시 ---
# BASE_DIR=/root/hyj/Team4
# DATA_DIR=/root/datasets
# HF_HOME=/root/.cache/huggingface
# CHECKPOINTS_DIR=/root/checkpoints
# SFT_CKPT=/root/checkpoints/checkpoint-26000
# BASE_MODEL=lmms-lab/llava-onevision-qwen2-7b-ov
# SALMONN2_CKPT=${CHECKPOINTS_DIR}/video_salmonn2_hf
# UNAV_ANNO=${DATA_DIR}/unav100_annotations.json
# UNAV_VIDEO_DIR=${DATA_DIR}/unav_100/videos
# UNAV_AUDIO_DIR=${DATA_DIR}/unav_100/audio
# PUVALOR_DIR=${DATA_DIR}/PU-VALOR
# VALOR_DIR=${DATA_DIR}/VALOR-32K/valor_videos
# CLAP_SRC=${BASE_DIR}/CLAP/src
# CLAP_CKPT=${BASE_DIR}/CLAP/630k-audioset-fusion-best.pt
# MERGE_OUT_DIR=${CHECKPOINTS_DIR}/merged

# --- 로컬 Windows (Git Bash) 예시 ---
# BASE_DIR=/d/code/Team4
# DATA_DIR=/d/data
# HF_HOME=/d/.cache/huggingface
# CHECKPOINTS_DIR=/d/checkpoints
# SFT_CKPT=/d/checkpoints-26000
# BASE_MODEL=lmms-lab/llava-onevision-qwen2-7b-ov
# SALMONN2_CKPT=${CHECKPOINTS_DIR}/video_salmonn2_hf
# UNAV_ANNO=${DATA_DIR}/unav100_annotations.json
# UNAV_VIDEO_DIR=${DATA_DIR}/unav_100/videos
# UNAV_AUDIO_DIR=${DATA_DIR}/unav_100/audio
# PUVALOR_DIR=${DATA_DIR}/PU-VALOR
# VALOR_DIR=${DATA_DIR}/VALOR-32K/valor_videos
# CLAP_SRC=${BASE_DIR}/CLAP/src
# CLAP_CKPT=${BASE_DIR}/CLAP/630k-audioset-fusion-best.pt
# MERGE_OUT_DIR=${CHECKPOINTS_DIR}/merged

# ============================================================
# 아래에 실제 값을 채워넣으세요
# ============================================================

# 프로젝트 루트
BASE_DIR=/d/vscode/AI-Living-Lab/cdh/Team4

# 원본 데이터 / 캐시
DATA_DIR=/d/vscode/AI-Living-Lab/datasets
HF_HOME=/d/vscode/AI-Living-Lab/huggingface

# 체크포인트 저장 디렉토리
CKPT_DIR=/d/vscode/AI-Living-Lab/checkpoints

# Json 데이터
JSON_DIR = ${BASE_DIR}/data

# 평가기록
EVAL_DIR = ${BASE_DIR}/outpus

# UnAV-100 비디오/오디오 원본 (데이터 전처리 시 필요)
UNAV_VIDEO_DIR=${DATA_DIR}/unav_100/videos
UNAV_AUDIO_DIR=${DATA_DIR}/unav_100/audio