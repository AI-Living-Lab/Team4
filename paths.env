# ============================================================
# paths.env - 실제 경로 설정 (git에 올라가지 않음)
# paths.env.example을 복사해서 수정하세요
# ============================================================

# 프로젝트 루트
# RUNPOD: BASE_DIR=/root/hyj/Team4
BASE_DIR=/d/code/Team4

# 데이터 / 캐시
# RUNPOD: DATA_DIR=/root/datasets
DATA_DIR=/d/data
# RUNPOD: HF_HOME=/root/.cache/huggingface
HF_HOME=/d/.cache/huggingface

# 체크포인트 저장 디렉토리
# RUNPOD: CHECKPOINTS_DIR=/root/checkpoints
CHECKPOINTS_DIR=/d/checkpoints

# SFT 체크포인트 (checkpoints-26000 폴더)
# RUNPOD: SFT_CKPT=/root/checkpoints/checkpoint-26000
SFT_CKPT=/d/checkpoints-26000

# 베이스 모델 (HuggingFace model ID 또는 로컬 경로)
# 원본: /mnt/bn/tiktok-mm-4/aiic/public/model/OV-Qwen2-7B-AM9
BASE_MODEL=lmms-lab/llava-onevision-qwen2-7b-ov
# RUNPOD: BASE_MODEL=lmms-lab/llava-onevision-qwen2-7b-ov  (동일)

# SALMONN2 사전학습 체크포인트 (video_salmonn2_hf)
# RUNPOD: SALMONN2_CKPT=${CHECKPOINTS_DIR}/video_salmonn2_hf
SALMONN2_CKPT=/d/checkpoints/video_salmonn2_hf

# UnAV-100 annotation JSON
# RUNPOD: UNAV_ANNO=${DATA_DIR}/unav100_annotations.json
UNAV_ANNO=/d/data/unav100_annotations.json

# UnAV-100 비디오/오디오 원본 (데이터 전처리 시 필요)
# RUNPOD: UNAV_VIDEO_DIR=${DATA_DIR}/unav_100/videos
UNAV_VIDEO_DIR=/d/data/unav_100/videos
# RUNPOD: UNAV_AUDIO_DIR=${DATA_DIR}/unav_100/audio
UNAV_AUDIO_DIR=/d/data/unav_100/audio

# PU-VALOR 데이터셋
# RUNPOD: PUVALOR_DIR=${DATA_DIR}/PU-VALOR
PUVALOR_DIR=/d/data/PU-VALOR
# RUNPOD: VALOR_DIR=${DATA_DIR}/VALOR-32K/valor_videos
VALOR_DIR=/d/data/VALOR-32K/valor_videos

# CLAP 모델 (eval/parse_and_eval.py에 필요)
# RUNPOD: CLAP_SRC=${BASE_DIR}/CLAP/src
CLAP_SRC=/d/code/Team4/CLAP/src
# RUNPOD: CLAP_CKPT=${BASE_DIR}/CLAP/630k-audioset-fusion-best.pt
CLAP_CKPT=/d/code/Team4/CLAP/630k-audioset-fusion-best.pt

# LoRA 머지 출력 디렉토리 (merge_lora_vs2.py에 필요)
# RUNPOD: MERGE_OUT_DIR=${CHECKPOINTS_DIR}/merged
MERGE_OUT_DIR=/d/checkpoints/merged
